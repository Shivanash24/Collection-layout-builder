{% if collection %}
  <div id="collection-layout-builder-root" 
       data-shop-domain="{{ shop.domain }}" 
       data-collection-id="{{ collection.id }}"
       style="width: 100%; min-height: 400px; display: flex; align-items: center; justify-content: center;"
  >
    <div class="clb-loading-spinner" style="border: 3px solid #f3f3f3; border-top: 3px solid #3498db; border-radius: 50%; width: 24px; height: 24px; animation: clb-spin 1s linear infinite;"></div>
  </div>

  <style>
    @keyframes clb-spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
  </style>

  <script>
    window.clbProducts = [
      {% for product in collection.products %}
        {
          id: {{ product.id | json }},
          title: {{ product.title | json }},
          price: {{ product.price | money | json }},
          image: {{ product.featured_image | img_url: 'master' | json }},
          url: {{ product.url | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];
  </script>

  <script src="{{ 'layout-renderer.js' | asset_url }}" defer></script>
{% else %}
  <div style="padding: 20px; background: #f8d7da; color: #721c24; text-align: center; border-radius: 8px;">
    <strong>Collection Layout Builder:</strong> This block can only be added to a Collection page.
  </div>
{% endif %}

{% schema %}
{
  "name": "Custom Collection Layout",
  "target": "section",
  "templates": ["collection"],
  "settings": [
    {
      "type": "paragraph",
      "content": "Configure your layout styles in the Collection Layout Builder app dashboard."
    }
  ]
}
{% endschema %}
